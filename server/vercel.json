{
  "version": 2,

  "builds": [
    {
      "src": "server/src/api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "client/dist"
      }
    }
  ],

  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server/src/api/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "/client/dist/index.html"
    }
  ]
}
